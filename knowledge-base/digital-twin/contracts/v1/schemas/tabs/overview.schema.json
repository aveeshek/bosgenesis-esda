{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bosgenesis.local/contracts/digital-twin/v1/tabs/overview.schema.json",
  "title": "Digital Twin Overview Tab",
  "x-contract-version": "1.0.0",
  "allOf": [{"$ref": "../common.schema.json#/$defs/tabEnvelope"}],
  "type": "object",
  "required": ["data"],
  "properties": {
    "data": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["decision", "policy_verdict", "evidence_completeness", "change_risk", "risk_score", "autonomy_eligibility", "dry_run_status", "rollback_confidence", "drift_status", "replay_status", "runtime_risk", "release_note_validation_status", "top_reasons", "blocking_findings", "warnings", "missing_evidence", "recommended_next_action"],
      "properties": {
        "decision": {"$ref": "../common.schema.json#/$defs/decisionLevel"},
        "policy_verdict": {"type": "string", "enum": ["pending", "allow", "allow_with_approval", "deny", "unknown"]},
        "evidence_completeness": {"type": "string", "enum": ["pending", "complete", "partial", "insufficient", "unknown"]},
        "change_risk": {"$ref": "../common.schema.json#/$defs/riskLevel"},
        "risk_score": {"type": ["number", "null"], "minimum": 0, "maximum": 100},
        "autonomy_eligibility": {"type": "string", "enum": ["pending", "eligible", "approval_required", "blocked", "ineligible", "historical_only"]},
        "dry_run_status": {"type": "string", "enum": ["pending", "running", "passed", "passed_with_warnings", "failed", "not_run", "stale"]},
        "rollback_confidence": {"type": "string", "enum": ["high", "medium", "low", "unavailable", "pending"]},
        "drift_status": {"type": "string", "enum": ["pending", "none", "minor", "major", "critical", "unknown"]},
        "replay_status": {"type": "string", "enum": ["not_run", "running", "passed", "failed", "not_available"]},
        "runtime_risk": {"$ref": "../common.schema.json#/$defs/riskLevel"},
        "release_note_validation_status": {"type": "string", "enum": ["not_run", "passed", "warning", "failed", "not_available"]},
        "top_reasons": {"type": "array", "maxItems": 5, "items": {"$ref": "../common.schema.json#/$defs/reason"}},
        "blocking_findings": {"type": "array", "items": {"$ref": "../common.schema.json#/$defs/finding"}},
        "warnings": {"type": "array", "items": {"$ref": "../common.schema.json#/$defs/finding"}},
        "missing_evidence": {"type": "array", "items": {"type": "string", "minLength": 1, "maxLength": 1000}},
        "recommended_next_action": {"type": "string", "minLength": 1, "maxLength": 1000}
      }
    }
  },
  "unevaluatedProperties": false
}

