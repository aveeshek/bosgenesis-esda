APP_ENV=local-ingress
APP_NAME=bosgenesis-esda
APP_BASE_URL=http://localhost:8080
SECRET_KEY=change-me-local

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# PostgreSQL stores run state, UI events, tool logs, and LLM review logs.
DATABASE_URL=postgresql+psycopg://postgres:replace-with-password@10.99.52.176:5432/esda

QDRANT_URL=http://qdrant.bosgenesis.local
ALLOWED_GITHUB_HOSTS=github.com
RELEASE_NOTE_AGENT_URL=http://release-note-agent.bosgenesis.local

AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_GPT5_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
AZURE_OPENAI_USE_V1_API=true
AZURE_OPENAI_REASONING_EFFORT=medium
AZURE_OPENAI_REASONING_SUMMARY=auto
AZURE_OPENAI_TIMEOUT_SECONDS=120

MCP_K8S_INSPECTOR_URL=http://k8s-inspector.bosgenesis.local
MCP_K8S_INSPECTOR_API_KEY=
POWERSHELL_RUNNER_URL=

ALLOWED_REST_HOSTS=localhost,127.0.0.1,.bosgenesis.local
DEFAULT_NAMESPACE=bosgenesis
