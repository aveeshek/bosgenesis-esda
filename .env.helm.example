APP_ENV=helm
APP_NAME=bosgenesis-esda
APP_BASE_URL=http://bosgenesis-esda.bosgenesis.local
SECRET_KEY=replace-from-k8s-secret

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-from-k8s-secret

# Helm deployment uses in-cluster PostgreSQL for run state, UI events, tool logs,
# and LLM review logs.
DATABASE_URL=postgresql+psycopg://esda:replace-from-k8s-secret@postgresql.bosgenesis.svc.cluster.local:5432/esda
POSTGRES_LOG_SCHEMA=public
ARTIFACT_STORAGE_DIR=var/artifacts

QDRANT_URL=http://qdrant.bosgenesis.svc.cluster.local:6333
REDIS_URL=
ALLOWED_GITHUB_HOSTS=github.com
RELEASE_NOTE_AGENT_URL=http://bosgenesis-release-note-agent-api.bosgenesis.svc.cluster.local:8080
RELEASE_NOTE_AGENT_MCP_URL=http://bosgenesis-release-note-agent-mcp.bosgenesis.svc.cluster.local:8090
RELEASE_NOTE_AGENT_TRANSPORT=auto
RELEASE_NOTE_AGENT_TIMEOUT_SECONDS=300

AZURE_OPENAI_AUTH_MODE=api_key
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=replace-from-k8s-secret
AZURE_OPENAI_GPT5_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
OPENAI_DEPLOYMENT=
OPENAI_API_VERSION=
AZURE_OPENAI_USE_V1_API=true
AZURE_OPENAI_REASONING_EFFORT=medium
AZURE_OPENAI_REASONING_SUMMARY=auto
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_MAX_TOKENS=2000
AZURE_OPENAI_TIMEOUT_SECONDS=120
AZURE_OPENAI_MAX_RETRIES=2
# Selectable LLM model profiles exposed in the UI.
LLM_DEFAULT_MODEL_PROFILE=azure_gpt5_pro
AZURE_OPENAI_GPT5_ENDPOINT=https://aiservicesprjbossdcdevh23aw001.openai.azure.com/
AZURE_OPENAI_GPT5_PRO_DEPLOYMENT=bos-trainium-gpt-5.0
AZURE_OPENAI_GPT5_MODEL_NAME=gpt-5
AZURE_OPENAI_GPT5_API_VERSION=2024-12-01-preview
AZURE_OPENAI_GPT41_MINI_DEPLOYMENT=bos-trainium-sigma-gpt-4.1-mini
AZURE_OPENAI_GPT41_MINI_MODEL_NAME=gpt-4.1-mini
OLLAMA_LLAMA70B_BASE_URL=http://ollama-llama70b.bosgenesis.local/v1
OLLAMA_LLAMA70B_MODEL=llama3.3:70b
OLLAMA_GEMMA_BASE_URL=http://ollama.bosgenesis.local/v1
OLLAMA_GEMMA_MODEL=gemma4:26b

LANGGRAPH_CHECKPOINTER=memory
LANGMEM_ENABLED=false
LLM_REVIEW_LOGGING_ENABLED=true

MCP_K8S_INSPECTOR_URL=http://bosgenesis-k8s-inspector-mcp.bosgenesis.svc.cluster.local
MCP_K8S_INSPECTOR_API_KEY=replace-from-k8s-secret-if-needed
POWERSHELL_RUNNER_URL=

ALLOWED_REST_HOSTS=localhost,127.0.0.1,.bosgenesis.local
DEFAULT_NAMESPACE=bosgenesis
