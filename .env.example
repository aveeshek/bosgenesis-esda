APP_ENV=local-docker
APP_NAME=bosgenesis-esda
APP_BASE_URL=http://localhost:8080
SECRET_KEY=change-me-in-real-env

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# PostgreSQL stores run state, UI events, tool logs, and LLM review logs.
DATABASE_URL=postgresql+psycopg://esda:esda@localhost:5432/esda
POSTGRES_LOG_SCHEMA=public
ARTIFACT_STORAGE_DIR=var/artifacts

QDRANT_URL=http://localhost:6333
REDIS_URL=
ALLOWED_GITHUB_HOSTS=github.com
RELEASE_NOTE_AGENT_URL=http://release-note-agent.bosgenesis.local
RELEASE_NOTE_AGENT_MCP_URL=http://release-note-agent.bosgenesis.local
RELEASE_NOTE_AGENT_TRANSPORT=auto
RELEASE_NOTE_AGENT_TIMEOUT_SECONDS=300

AZURE_OPENAI_AUTH_MODE=api_key
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_GPT5_DEPLOYMENT=
AZURE_OPENAI_API_VERSION=
# OPENAI_DEPLOYMENT and OPENAI_API_VERSION are supported aliases.
OPENAI_DEPLOYMENT=
OPENAI_API_VERSION=
AZURE_OPENAI_USE_V1_API=true
AZURE_OPENAI_REASONING_EFFORT=medium
AZURE_OPENAI_REASONING_SUMMARY=auto
AZURE_OPENAI_TEMPERATURE=0.2
AZURE_OPENAI_MAX_TOKENS=2000
AZURE_OPENAI_TIMEOUT_SECONDS=120
AZURE_OPENAI_MAX_RETRIES=2

LANGGRAPH_CHECKPOINTER=memory
LANGMEM_ENABLED=false
LLM_REVIEW_LOGGING_ENABLED=true

MCP_K8S_INSPECTOR_URL=
MCP_K8S_INSPECTOR_API_KEY=
POWERSHELL_RUNNER_URL=

ALLOWED_REST_HOSTS=localhost,127.0.0.1
DEFAULT_NAMESPACE=bosgenesis
